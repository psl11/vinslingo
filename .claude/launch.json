{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "vinslingo-web",
      "runtimeExecutable": "npx",
      "runtimeArgs": [
        "expo",
        "start",
        "--web",
        "--port",
        "8081"
      ],
      "port": 8081
    },
    {
      "name": "vinslingo-web-static",
      "runtimeExecutable": "npx",
      "runtimeArgs": [
        "serve",
        "dist",
        "-p",
        "8090"
      ],
      "port": 8090
    }
  ]
}